# Google Maps API Key (required)
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable these APIs: Maps JavaScript API, Places API
VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# Google Maps Map ID (optional, for custom styled maps / AdvancedMarkers)
# Create one at: https://console.cloud.google.com/google/maps-api/studio/maps
VITE_GOOGLE_MAPS_MAP_ID=

# Site URL (used for canonical links, Open Graph tags, etc.)
# Set to your deployed domain, e.g. https://essenceqc.ca
VITE_SITE_URL=https://essenceqc.ca
